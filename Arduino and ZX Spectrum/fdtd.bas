10 REM 1D ACOUSTIC FDTD GAUSSIAN
20 LET KX=120
30 LET NT=300

40 DIM P(KX)
50 DIM U(KX)
60 DIM C(KX)
70 DIM G(40)

80 LET S=0.20

90 REM INITIALISE
100 FOR K=1 TO KX
110 LET P(K)=0
120 LET U(K)=0
130 LET C(K)=1
140 NEXT K

150 REM MATERIAL INTERFACE
160 LET I=60
170 FOR K=I TO KX
180 LET C(K)=0.667
190 NEXT K

200 REM GAUSSIAN TABLE
210 FOR J=1 TO 40
220 LET X=(J-20)/8
230 LET G(J)=EXP(-X*X)
240 NEXT J

250 REM ABSORBING BOUNDARIES
260 LET A=0
270 LET B=0
280 LET D=0
290 LET E=0

300 REM MAIN LOOP
310 FOR N=1 TO NT

320 REM PRESSURE UPDATE
330 FOR K=2 TO KX
340 LET Q=S*C(K)*C(K)
350 LET P(K)=P(K)+Q*(U(K-1)-U(K))
360 NEXT K


370 REM GAUSSIAN SOURCE
380 LET J=INT((N-80)/2)+20
390 IF J<1 THEN GOTO 430
400 IF J>40 THEN GOTO 430
410 LET P(20)=P(20)+G(J)

430 REM LEFT ABC
440 LET P(1)=A
450 LET A=B
460 LET B=P(2)

470 REM RIGHT ABC
480 LET P(KX)=D
490 LET D=E
500 LET E=P(KX-1)


510 REM VELOCITY UPDATE
520 FOR K=1 TO KX-1
530 LET U(K)=U(K)+S*(P(K)-P(K+1))
540 NEXT K


550 REM DISPLAY EVERY 4 STEPS
560 IF N/4<>INT(N/4) THEN GOTO 640

570 CLS
580 PRINT "1D ACOUSTIC FDTD"
590 PRINT "STEP ";N

600 FOR K=1 TO KX
610 LET Y=96-P(K)*40
620 IF Y<0 THEN LET Y=0
630 IF Y>175 THEN LET Y=175
635 PLOT K*2,Y
636 NEXT K

640 PAUSE 1

650 NEXT N

660 STOP
